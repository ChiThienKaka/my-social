# Backend API (axios baseURL). Thiết bị thật: dùng IP máy chạy API (cùng Wi‑Fi), không dùng localhost.
# Ví dụ: http://192.168.1.10:8000 hoặc https://api.example.com
EXPO_PUBLIC_API_URL=

# Google OAuth — Web Client ID (Google Cloud Console / Firebase). Cần khớp cấu hình backend.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# (Tùy chọn, build Android native) Đường dẫn tới google-services.json nếu không đặt ở root project.
# GOOGLE_SERVICES_JSON=

npx login 
php artisan serve --host=0.0.0.0 --port=8000